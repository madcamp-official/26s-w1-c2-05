# /etc/systemd/system/linguaai-backend.service
[Unit]
Description=LinguaAI FastAPI backend
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/var/www/linguaai/backend
ExecStart=/var/www/linguaai/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
